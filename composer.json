{
    "name": "moyefu/translator",
    "description": "A PHP library for integrating with various translation APIs (Baidu, Google, Youdao, Tencent, Ali, Volcengine, Microsoft, etc.)",
    "type": "library",
    "version": "1.0.0",
    "require": {
        "php": ">=5.6",
        "guzzlehttp/guzzle": "^6.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^6.5 || ^7.5 || ^8.5"
    },
    "autoload": {
        "psr-4": {
            "Moyefu\\Core\\": "src/core/",
            "Moyefu\\Translators\\": "src/translators/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moyefu\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "license": "MIT",
    "config": {
        "audit": {
            "block-insecure": false
        }
    }
}